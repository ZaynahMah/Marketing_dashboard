# Gemini AI strategy layer (OPTIONAL).
# Without these, the dashboard runs fully on the deterministic engine and the
# AI strategy sections fall back to deterministic output.

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Defaults to gemini-2.5-flash if unset.
# Options: gemini-2.5-flash | gemini-2.5-flash-lite | gemini-2.5-pro | gemini-3.5-flash | gemini-3.1-pro-preview
GEMINI_MODEL=gemini-2.5-flash
